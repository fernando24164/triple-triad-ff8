# =============================================================================
# Integration Test Scenarios
# =============================================================================
# Each scenario defines environment variables passed to docker-compose.
# Run any scenario with:
#   ./run_multiplayer_test.sh --scenario <name>
#
# To add a new scenario, add an entry to the `scenarios` associative array
# and document what it tests.
# =============================================================================

# Default: basic P2P game, Open rules, auto-generated decks
SCENARIO_DEFAULT=""

# Stress test: shorter heartbeat to detect timeouts faster
SCENARIO_STRESS="HEARTBEAT_INTERVAL=2 HEARTBEAT_TIMEOUT=5"

# Long game: larger timeout for slow CI environments
SCENARIO_CI="HOST_PORT=64001 LOG_LEVEL=DEBUG"

# Isolated network: custom subnet to test IP-based addressing
SCENARIO_CUSTOM_PORT="HOST_PORT=65000"
